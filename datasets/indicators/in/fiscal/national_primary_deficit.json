    "value_kind": "currency",
    "direction": "lower_is_better",
    "scale_hint": "linear",
    "unit": "INR (crore)",
    "icon": "trending-down",
    "attribution_geography": "where_administered",
    "comparability": "comparable_with_normalisation",
    "funding_split": {
      "centre_pct": 0,
      "state_pct": 100,
      "source": "definition (states' own budgetary deficits)"
    },
    "implementing_authority": "state",
    "methodology_vintage": "RBI State Finances: A Study of Budgets, Appendix Table 1 (Major Deficit Indicators); cached file mtime 2026-05-11T06:28:31Z",
    "notes": "Source: RBI 'State Finances: A Study of Budgets', Appendix Table 1, column 'Primary Deficit'. Same caveats as the gross fiscal deficit indicator."

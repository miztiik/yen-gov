  "indicator": {
    "id": "energy/state_acs_arr_gap_inr_per_kwh",
    "title": "ACS-ARR gap on electricity sales (Rs/kWh, by state)",
    "description": "Average Cost of Supply minus Average Revenue Realised, per unit of electricity sold. Positive = the utility loses money on every unit it sells (cost > revenue). Negative = surplus. Zero is the policy goal under UDAY/RDSS — utilities should neither subsidise consumption nor extract rent.",
    "entity_kind": "state",
    "time_grain": "fiscal_year",
    "value_kind": "currency",
    "direction": "lower_is_better",
    "scale_hint": "linear",
    "unit": "INR/kWh",
    "icon": "dollar-sign",
    "attribution_geography": "where_administered",
    "comparability": "comparable_with_normalisation",
    "implementing_authority": "state",
    "methodology_vintage": "NITI Aayog ICED state-wise deep-dive API; payload fetched 2026-05-14T07:51:49Z; 10 fiscal years, 314 rows.",
    "notes": "Source: NITI Aayog ICED dashboard, row 'ACS-ARR (Electricity Sales) Gap'. Calculated by PFC from utility tariff orders + audited accounts. Note the opposite sign convention from fiscal-deficit indicators: here a *negative* number is the surplus side."

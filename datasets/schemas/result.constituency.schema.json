{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yen-gov.github.io/schemas/result.constituency.schema.json",
  "title": "Per-constituency result",
  "description": "Result for a single constituency in a single election event. Includes top-N candidates plus NOTA, with remaining candidates collapsed into an 'others' bucket per processing config.",
  "x-version": "3.0",
  "x-changelog": [
    {
      "version": "1.0",
      "date": "2026-05-08",
      "description": "Initial schema. Election + (state, body, eci_no) key, candidates list, NOTA, totals, turnout, winner, top-N config snapshot, others bucket."
    },
    {
      "version": "2.0",
      "date": "2026-05-08",
      "description": "Replaced optional source_url with required source field per provenance contract (CLAUDE.md §12)."
    },
    {
      "version": "3.0",
      "date": "2026-05-08",
      "description": "Replaced single source string with sources array of {url, fetched_at} per ADR-0002. Removed top-level fetched_at (now lives inside each sources entry)."
    }
  ],
  "type": "object",
  "required": [
    "$schema", "$schema_version", "sources", "election", "state", "body", "eci_no",
    "candidates", "nota", "totals", "winner", "top_n_cutoff"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "$schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "sources": {
      "type": "array",
      "description": "Provenance per CLAUDE.md §12 / ADR-0002. Each entry is one upstream URL plus the timestamp our pipeline fetched it. An empty array signals hand-authored content.",
      "items": {
        "type": "object",
        "required": ["url", "fetched_at"],
        "additionalProperties": false,
        "properties": {
          "url": { "type": "string", "format": "uri", "pattern": "^https?://" },
          "fetched_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "election": { "type": "string", "minLength": 1 },
    "state": { "type": "string", "pattern": "^[SU]\\d{2}$" },
    "body": { "enum": ["AC", "PC"] },
    "eci_no": { "type": "integer", "minimum": 1 },
    "constituency_name": { "type": "string", "minLength": 1 },
    "totals": {
      "type": "object",
      "required": ["votes_polled"],
      "additionalProperties": false,
      "properties": {
        "electors": { "type": ["integer", "null"], "minimum": 0 },
        "votes_polled": { "type": "integer", "minimum": 0 },
        "turnout_pct": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "description": "Top-N candidates by vote count, in descending rank order. Excludes NOTA (broken out separately) and excludes candidates collapsed into 'others'.",
      "items": {
        "type": "object",
        "required": ["rank", "name", "votes", "vote_share_pct"],
        "additionalProperties": false,
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "name": { "type": "string", "minLength": 1 },
          "party_eci_code": {
            "type": ["string", "null"],
            "pattern": "^\\d+$",
            "description": "Null for independents."
          },
          "party_short": { "type": "string", "minLength": 1 },
          "votes": { "type": "integer", "minimum": 0 },
          "vote_share_pct": { "type": "number", "minimum": 0, "maximum": 100 },
          "is_winner": { "type": "boolean" }
        }
      }
    },
    "nota": {
      "type": "object",
      "required": ["votes", "vote_share_pct"],
      "additionalProperties": false,
      "properties": {
        "votes": { "type": "integer", "minimum": 0 },
        "vote_share_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "others": {
      "type": ["object", "null"],
      "description": "Collapsed bucket of candidates ranked below top_n_cutoff. Null if no collapsing occurred.",
      "required": ["candidate_count", "votes", "vote_share_pct"],
      "additionalProperties": false,
      "properties": {
        "candidate_count": { "type": "integer", "minimum": 1 },
        "votes": { "type": "integer", "minimum": 0 },
        "vote_share_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "top_n_cutoff": {
      "type": "integer",
      "minimum": 1,
      "description": "Snapshot of processing.results.top_n_candidates at emit time. Reproducible derivations require this."
    },
    "winner": {
      "type": "object",
      "required": ["name", "votes", "margin_votes", "margin_pct"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "party_eci_code": { "type": ["string", "null"], "pattern": "^\\d+$" },
        "party_short": { "type": "string", "minLength": 1 },
        "votes": { "type": "integer", "minimum": 0 },
        "margin_votes": {
          "type": "integer",
          "minimum": 0,
          "description": "Votes ahead of the runner-up."
        },
        "margin_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Margin as percentage of votes_polled."
        }
      }
    }
  }
}
